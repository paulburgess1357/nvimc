#!/usr/bin/env bash
# nvim-open — Open files in a running Neovim instance.
#
# Accepts one or more absolute/relative paths (fast path) or a single filename
# pattern to search for under Neovim's working directory. Uses nvim-send for
# Neovim communication.
#
# Interface:
#   nvim-open <file> [file2 ...]       Open one or more files
#   nvim-open -g <line> <file>         Open a file and jump to a line number
#   nvim-open -s <socket> <file>       Use a specific Neovim server socket
#   nvim-open -l <pattern>             List matching files without opening
#   nvim-open -n <N> <pattern>         Open the Nth search result
#
# Behavior:
#   - Multiple file arguments are supported; each is opened as a buffer.
#   - If an argument is an existing file path, opens it directly (no search).
#   - Otherwise, searches Neovim's cwd for files matching *<pattern>*.
#   - Skips build artifacts: build/, .cache/, node_modules/, .git/, etc.
#   - -g only applies to the last file opened.
#   - Prints "Opened: <path>" for each file on success to stdout.
#   - Errors and multi-match warnings go to stderr.
#
# Dependencies:
#   - nvim-send (must be in the same directory or on PATH)
#
# Exit codes:
#   0  Success
#   1  No socket found / no matches / invalid pick index

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NVIM_SEND="${SCRIPT_DIR}/nvim-send"

usage() {
  cat <<'EOF'
Usage: nvim-open [OPTIONS] <path|pattern> [path2 ...]

Find and open files in a running Neovim instance.

If an argument is an existing file (absolute or relative path), it is opened
directly. Otherwise, searches Neovim's cwd for files matching *<pattern>*.
Multiple files can be specified to open them all as buffers.

Options:
  -s, --socket PATH   Neovim server socket path (auto-detected if omitted)
  -g, --goto LINE      Jump to line number after opening (applies to last file)
  -l, --list           List matches instead of opening
  -n, --pick N         Open the Nth match (1-indexed, default: 1)
  -h, --help           Show this help

Examples:
  nvim-open Entity.cpp                              Search and open
  nvim-open Entity.cpp main.cpp Component.cpp       Open multiple files
  nvim-open -g 42 Entity.cpp                        Open and jump to line 42
  nvim-open /home/user/proj/src/Entity.cpp          Open by exact path
  nvim-open -l Entity                               List all matches
  nvim-open -n 2 Entity.cpp                         Open the 2nd match
EOF
  exit 0
}

SOCKET_ARGS=()
LIST=false
PICK=1
GOTO=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--socket) SOCKET_ARGS=(-s "$2"); shift 2 ;;
    -g|--goto)   GOTO="$2"; shift 2 ;;
    -l|--list)   LIST=true; shift ;;
    -n|--pick)   PICK="$2"; shift 2 ;;
    -h|--help)   usage ;;
    -*)          echo "Unknown option: $1" >&2; exit 1 ;;
    *)           break ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "Error: filename required" >&2
  usage
fi

open_file() {
  local file="$1"
  "$NVIM_SEND" "${SOCKET_ARGS[@]+"${SOCKET_ARGS[@]}"}" -c "e ${file}"
  echo "Opened: ${file}"
}

search_and_open() {
  local pattern="$1"

  NVIM_CWD=$("$NVIM_SEND" "${SOCKET_ARGS[@]+"${SOCKET_ARGS[@]}"}" -e "getcwd()") || {
    echo "Error: could not query Neovim cwd" >&2
    exit 1
  }

  local prune_dirs=( build .cache node_modules .git __pycache__ .mypy_cache dist .next .tox .eggs "*.egg-info" )
  local prune_expr=()
  for d in "${prune_dirs[@]}"; do
    prune_expr+=( -name "$d" -o )
  done
  unset 'prune_expr[-1]'

  local matches
  mapfile -t matches < <(
    find "$NVIM_CWD" \( "${prune_expr[@]}" \) -prune -o -type f -name "*${pattern}*" -print 2>/dev/null | sort
  )

  if [[ ${#matches[@]} -eq 0 ]]; then
    echo "No files matching '*${pattern}*' found under ${NVIM_CWD}" >&2
    return 1
  fi

  if $LIST; then
    for i in "${!matches[@]}"; do
      printf "  %d) %s\n" $((i + 1)) "${matches[$i]}"
    done
    return 0
  fi

  if [[ ${#matches[@]} -gt 1 && "$PICK" -eq 1 ]]; then
    echo "Multiple matches found:" >&2
    for i in "${!matches[@]}"; do
      printf "  %d) %s\n" $((i + 1)) "${matches[$i]}" >&2
    done
    echo "" >&2
    echo "Opening match #1. Use -n N to pick a different one, or -l to list." >&2
  fi

  local index=$((PICK - 1))
  if [[ $index -lt 0 || $index -ge ${#matches[@]} ]]; then
    echo "Error: pick index ${PICK} out of range (1-${#matches[@]})" >&2
    return 1
  fi

  open_file "${matches[$index]}"
}

ARGS=("$@")

for arg in "${ARGS[@]}"; do
  if [[ -f "$arg" ]]; then
    open_file "$(realpath "$arg")"
  else
    search_and_open "$arg"
  fi
done

if [[ -n "$GOTO" ]]; then
  "$NVIM_SEND" "${SOCKET_ARGS[@]+"${SOCKET_ARGS[@]}"}" -c "${GOTO}"
  echo "Jumped to line ${GOTO}"
fi
